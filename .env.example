# Server Configuration
# PORT=3000

# Chunk size in bytes (default: 64MB = 67108864)
CHUNK_SIZE=67108864

# Maximum file size allowed for download (-1 for unlimited)
MAX_FILE_SIZE=-1

# TOTP Secret Key (Base32 encoded string)
# Generate using: node -e "console.log(require('crypto').randomBytes(20).toString('base32'))"
TOTP_SECRET=YOUR_TOTP_SECRET_HERE

# 2FA Token expiration time in seconds (default: 7 days = 604800 seconds)
TOKEN_EXPIRY=604800

# Encryption key for encrypting part parameters (use a strong random string)
# Generated by `openssl rand -base64 32`
ENCRYPTION_KEY=YOUR_ENCRYPTION_KEY_HERE
